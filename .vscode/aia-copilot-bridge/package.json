{
  "name": "aia-copilot-bridge",
  "displayName": "AIA Symbol Index for Copilot",
  "description": "Enhances GitHub Copilot with AIA's O(1) symbol lookup",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "aia.rebuildSymbolIndex",
        "title": "AIA: Rebuild Symbol Index"
      },
      {
        "command": "aia.showSymbolStats",
        "title": "AIA: Show Symbol Statistics"
      },
      {
        "command": "aia.showPerformanceReport",
        "title": "AIA: Show Performance Report"
      },
      {
        "command": "aia.updateCopilotInstructions",
        "title": "AIA: Update Copilot Instructions"
      },
      {
        "command": "aia.toggleAutoUpdate",
        "title": "AIA: Toggle Auto-Update"
      }
    ],
    "configuration": {
      "title": "AIA Symbol Index",
      "properties": {
        "aia.symbolIndex.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically update symbol index on file changes"
        },
        "aia.symbolIndex.updateInterval": {
          "type": "number",
          "default": 300000,
          "description": "Update interval in milliseconds"
        },
        "aia.symbolIndex.includeInCopilotContext": {
          "type": "boolean",
          "default": true,
          "description": "Include symbol index in GitHub Copilot context"
        },
        "aia.symbolIndex.performanceTracking": {
          "type": "boolean",
          "default": true,
          "description": "Enable performance tracking for symbol lookups"
        },
        "aia.symbolIndex.debounceDelay": {
          "type": "number",
          "default": 2000,
          "description": "Delay in milliseconds before triggering auto-update after file changes"
        },
        "aia.symbolIndex.showUpdateNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show notifications when auto-updates complete"
        },
        "aia.symbolIndex.watchFileTypes": {
          "type": "array",
          "default": [
            "ts",
            "js",
            "tsx",
            "jsx",
            "md"
          ],
          "description": "File extensions to watch for auto-updates"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.101.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "fs-extra": "^11.3.0"
  }
}
