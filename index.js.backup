    );
    console.log(
      chalk.white(
        '  aia workflow-info              - Show workflow information'
      )
    );
    console.log(
      chalk.white('  aia workflow-delete            - Delete a workflow')
    );
  });

program
  .command('workflow-start-recording <name>')
  .description('Start recording a new workflow')
  .option('-d, --description <desc>', 'Workflow description')
  .option('-a, --author <author>', 'Workflow author')
  .option('-t, --tags <tags>', 'Comma-separated tags')
  .action(async (name, options) => {
    await aia.init();

    try {
      const recordingOptions = {
        description: options.description,
        author: options.author,
        tags: options.tags ? options.tags.split(',').map((t) => t.trim()) : [],
      };

      const result = await aia.workflowManager.startRecording(
        name,
        recordingOptions
      );

      if (result.success) {
        console.log(chalk.green(`🔴 Started recording workflow: "${name}"`));
        console.log(
          chalk.gray(
            'Execute commands to record them. Use "aia workflow-stop-recording" to finish.'
          )
        );
      }
    } catch (error) {
      console.error(chalk.red('Failed to start recording:', error.message));
    }
  });

program
  .command('workflow-stop-recording')
  .description('Stop recording and save the current workflow')
  .action(async () => {
    await aia.init();

    try {
      const result = await aia.workflowManager.stopRecording();

      if (result.success) {
        console.log(
          chalk.green(
            `✅ Workflow "${result.name}" saved with ${result.steps} steps`
          )
        );
        console.log(chalk.gray(`Saved to: ${result.path}`));
      }
    } catch (error) {
      console.error(chalk.red('Failed to stop recording:', error.message));
    }
  });

program
  .command('workflow-list')
  .description('List all available workflows')
  .action(async () => {
    await aia.init();
    const workflows = aia.workflowManager.listWorkflows();

    console.log(chalk.blue('🔄 Available Workflows'));

    if (workflows.length === 0) {
      console.log(chalk.gray('No workflows found.'));
      console.log(
        chalk.yellow(
          '💡 Create workflows with: aia workflow-start-recording <name>'
        )
      );
      return;
    }

    workflows.forEach((workflow) => {
      console.log(chalk.white(`📋 ${workflow.name}`));
      if (workflow.description) {
        console.log(chalk.gray(`   ${workflow.description}`));
      }
      console.log(chalk.gray(`   Steps: ${workflow.steps?.length || 0}`));
      console.log(
        chalk.gray(`   Created: ${new Date(workflow.created).toLocaleString()}`)
      );
      if (workflow.metadata?.tags && workflow.metadata.tags.length > 0) {
        console.log(
          chalk.gray(`   Tags: ${workflow.metadata.tags.join(', ')}`)
        );
      }
    });
  });

program
  .command('workflow-execute <name>')
  .description('Execute a workflow')
  .option('-v, --verbose', 'Show detailed execution information')
  .action(async (name, options) => {
    await aia.init();
    const spinner = ora('🔄 Executing workflow...').start();

    try {
      const result = await aia.workflowManager.executeWorkflow(name, {
        verbose: options.verbose,
      });
      spinner.stop();

      if (result.success) {
        console.log(chalk.green(`✅ Workflow "${name}" executed successfully`));
        console.log(chalk.white(`Steps executed: ${result.stepsExecuted}`));
        if (result.duration) {
          console.log(chalk.gray(`Duration: ${result.duration}ms`));
        }
      } else {
        console.log(chalk.red(`❌ Workflow execution failed: ${result.error}`));
        if (result.failedStep) {
          console.log(chalk.gray(`Failed at step: ${result.failedStep}`));
        }
      }
    } catch (error) {
      spinner.stop();
      console.error(chalk.red('Execution failed:', error.message));
    }
  });

program
  .command('workflow-info <name>')
  .description('Show detailed workflow information')
  .action(async (name) => {
    await aia.init();
    const workflow = aia.workflowManager.getWorkflowInfo(name);

    if (!workflow) {
      console.log(chalk.red(`❌ Workflow "${name}" not found`));
      return;
    }

    console.log(chalk.blue(`🔄 Workflow Information: ${workflow.name}`));
    console.log(
      chalk.white(`Description: ${workflow.description || 'No description'}`)
    );
    console.log(
      chalk.white(`Created: ${new Date(workflow.created).toLocaleString()}`)
    );
    console.log(chalk.white(`Steps: ${workflow.steps?.length || 0}`));

    if (workflow.metadata) {
      if (workflow.metadata.author) {
        console.log(chalk.white(`Author: ${workflow.metadata.author}`));
      }
      if (workflow.metadata.version) {
        console.log(chalk.white(`Version: ${workflow.metadata.version}`));
      }
      if (workflow.metadata.tags && workflow.metadata.tags.length > 0) {
        console.log(chalk.white(`Tags: ${workflow.metadata.tags.join(', ')}`));
      }
    }

    if (workflow.steps && workflow.steps.length > 0) {
      console.log(chalk.white('\nSteps:'));
      workflow.steps.forEach((step, index) => {
        console.log(
          chalk.gray(
            `  ${index + 1}. ${step.type}: ${
              step.command || step.query || 'Unknown'
            }`
          )
        );
        if (step.args && step.args.length > 0) {
          console.log(chalk.gray(`     Args: ${step.args.join(' ')}`));
        }
      });
    }
  });

program
  .command('workflow-delete <name>')
  .description('Delete a workflow')
  .action(async (name) => {
    await aia.init();

    const workflow = aia.workflowManager.getWorkflowInfo(name);
    if (!workflow) {
      console.log(chalk.red(`❌ Workflow "${name}" not found`));
      return;
    }

    const { confirm } = await inquirer.prompt([
      {
        type: 'confirm',
        name: 'confirm',
        message: `Are you sure you want to delete workflow "${name}"?`,
        default: false,
      },
    ]);

    if (!confirm) {
      console.log(chalk.gray('Deletion cancelled.'));
      return;
    }

    try {
      const result = await aia.workflowManager.deleteWorkflow(name);

      if (result.success) {
        console.log(chalk.green(`✅ Workflow "${name}" deleted successfully`));
      } else {
        console.log(chalk.red(`❌ Failed to delete workflow: ${result.error}`));
      }
    } catch (error) {
      console.error(chalk.red('Deletion failed:', error.message));
    }
  });

// Interactive mode when no arguments provided
if (process.argv.length === 2) {
  (async () => {
    await aia.init();
    console.log(chalk.blue('🤖 Welcome to AIA - AI Agentic Assistant'));
    console.log(
      chalk.gray('Type "help" for available commands or ask me anything!')
    );

    while (true) {
      try {
        const { action } = await inquirer.prompt([
          {
            type: 'input',
            name: 'action',
            message: chalk.cyan('aia>'),
          },
        ]);

  .command('workflow-info <name>')
  .description('Show detailed workflow information')
  .action(async (name) => {     action.toLowerCase() === 'quit'
    await aia.init();   ) {
          console.log(chalk.yellow('👋 Goodbye!'));
          break;
        } else if (action.toLowerCase() === 'help') {
          program.help();
        } else if (action.trim()) {
          await aia.askAI(action);
        }
      } catch (error) {
        if (error.isTtyError || error.message.includes('SIGINT')) {
          console.log(chalk.yellow('\n👋 Goodbye!'));
          break;
        }
        console.error(chalk.red('Error:', error.message));
      }
    }
  })();
} else {
  // For command mode, pre-load plugins to register their commands
  (async () => {
    await preloadPluginsForCLI();
    program.parse();
  })();
}
