#!/usr/bin/env node

const { Command } = require('commander');
const { spawn, exec } = require('child_process');
const fs = require('fs-extra');
const path = require('path');
const os = require('os');
const chalk = require('chalk');
const ora = require('ora');
const inquirer = require('inquirer');
const OpenAI = require('openai');
const Anthropic = require('@anthropic-ai/sdk');

// Phase 2 Enhanced Intelligence Modules
const ModelSelector = require('./src/ModelSelector');
const ContextAnalyzer = require('./src/ContextAnalyzer');
const CommandIntelligence = require('./src/CommandIntelligence');
const MemoryManager = require('./src/MemoryManager');

// Phase 3 Advanced Features Modules
const PluginManager = require('./src/PluginManager');
const WorkflowManager = require('./src/WorkflowManager');

// Initialize program
const program = new Command();

// Configuration and memory paths
const CONFIG_DIR = path.join(os.homedir(), '.aia');
const MEMORY_FILE = path.join(CONFIG_DIR, 'memory.json');
const CONFIG_FILE = path.join(CONFIG_DIR, 'config.json');
const PLUGINS_DIR = path.join(CONFIG_DIR, 'plugins');
const WORKFLOWS_DIR = path.join(CONFIG_DIR, 'workflows');

class AIA {
  constructor() {
    this.memory = {};
    this.config = {};
    this.context = {};
    this.openai = null;
    this.anthropic = null;
    this.initialized = false;

    // Phase 2: Enhanced Intelligence Components
    this.modelSelector = new ModelSelector();
    this.contextAnalyzer = new ContextAnalyzer();
    this.commandIntelligence = new CommandIntelligence();
    this.memoryManager = new MemoryManager(MEMORY_FILE);

    // Phase 3: Advanced Features Components
    this.pluginManager = new PluginManager(PLUGINS_DIR);
    this.workflowManager = new WorkflowManager(WORKFLOWS_DIR);
  }

  async init() {
    if (this.initialized) return;

    // Ensure config directory exists
    await fs.ensureDir(CONFIG_DIR);

    // Load memory and config
    this.memory = await this.memoryManager.loadMemory();
    await this.loadConfig();

    // Initialize AI clients
    this.initializeAI();

    // Gather context
    await this.gatherContext();

    // Phase 3: Load plugins and workflows
    await this.loadPlugins();
    await this.loadWorkflows();

    this.initialized = true;
  }

  async loadWorkflows() {
    try {
      // Initialize workflow manager
      await this.workflowManager.initialize();
    } catch (error) {
      console.warn(chalk.yellow('Workflow loading warning:', error.message));
    }
  }

  async loadPlugins() {
    try {
      // Execute startup hooks for plugins
      await this.pluginManager.executeHooks('onStartup', {
        aia: this,
        context: this.context,
        config: this.config,
      });

      // Load all available plugins
      await this.pluginManager.loadAllPlugins();

      // Register plugin commands with Commander.js
      this.registerPluginCommands();
    } catch (error) {
      console.warn(chalk.yellow('Plugin loading warning:', error.message));
    }
  }

  // Register plugin custom commands with Commander.js
  registerPluginCommands() {
    if (!this.pluginManager.pluginCommands) {
      return;
    }

    for (const [commandName, commandInfo] of this.pluginManager
      .pluginCommands) {
      try {
        program
          .command(commandName)
          .description(commandInfo.description)
          .action(async (...args) => {
            await this.init();

            try {
              // Execute beforeCommand hooks
              await this.pluginManager.executeHooks('beforeCommand', {
                command: commandName,
                args: args.slice(0, -1), // Remove options object
                options: args[args.length - 1], // Last arg is options
                aia: this,
                context: this.context,
              });

              // Execute the plugin command
              const result = await commandInfo.handler.call(null, {
                args: args.slice(0, -1),
                options: args[args.length - 1],
                aia: this,
                context: this.context,
                config: this.config,
                workingDirectory:
                  this.context.workingDirectory || process.cwd(),
              });

              // Execute afterCommand hooks
              await this.pluginManager.executeHooks('afterCommand', {
                command: commandName,
                args: args.slice(0, -1),
                options: args[args.length - 1],
                result,
                aia: this,
                context: this.context,
              });
            } catch (error) {
              console.error(
                chalk.red(
                  `Plugin command '${commandName}' failed:`,
                  error.message
                )
              );

              // Execute error hooks
              await this.pluginManager.executeHooks('onError', {
                error,
                command: commandName,
                aia: this,
                context: this.context,
              });
            }
          });

        console.log(
          chalk.green(
            `✅ Registered CLI command: aia ${commandName} (from ${commandInfo.pluginName})`
          )
        );
      } catch (error) {
        console.warn(
          chalk.yellow(
            `Failed to register command '${commandName}':`,
            error.message
          )
        );
      }
    }
  }

  async saveMemory() {
    try {
      await this.memoryManager.saveMemory();
    } catch (error) {
      console.error(chalk.red('Error saving memory:', error.message));
    }
  }

  async loadConfig() {
    try {
      if (await fs.pathExists(CONFIG_FILE)) {
        this.config = await fs.readJson(CONFIG_FILE);
      } else {
        this.config = {
          preferredModel: 'gpt-4',
          openaiApiKey: process.env.OPENAI_API_KEY,
          anthropicApiKey: process.env.ANTHROPIC_API_KEY,
        };
        await this.saveConfig();
      }
    } catch (error) {
      console.error(chalk.red('Error loading config:', error.message));
      this.config = { preferredModel: 'gpt-4' };
    }
  }

  async saveConfig() {
    try {
      await fs.writeJson(CONFIG_FILE, this.config, { spaces: 2 });
    } catch (error) {
      console.error(chalk.red('Error saving config:', error.message));
    }
  }

  initializeAI() {
    if (this.config.openaiApiKey) {
      this.openai = new OpenAI({ apiKey: this.config.openaiApiKey });
    }
    if (this.config.anthropicApiKey) {
      this.anthropic = new Anthropic({ apiKey: this.config.anthropicApiKey });
    }
  }

  async gatherContext() {
    const cwd = process.cwd();

    // Basic context gathering
    this.context = {
      workingDirectory: cwd,
      platform: os.platform(),
      arch: os.arch(),
      nodeVersion: process.version,
      user: os.userInfo().username,
      shell: process.env.SHELL || 'unknown',
    };

    // Check for project files
    const projectFiles = [
      'package.json',
      'requirements.txt',
      'Cargo.toml',
      'go.mod',
      'pom.xml',
    ];
    for (const file of projectFiles) {
      const filePath = path.join(cwd, file);
      if (await fs.pathExists(filePath)) {
        try {
          this.context.projectType = file;
          this.context.projectInfo = await fs.readJson(filePath);
        } catch (error) {
          this.context.projectType = file;
        }
        break;
      }
    }

    // Check git status
    try {
      const gitStatus = await this.execPromise(
        'git status --porcelain 2>/dev/null'
      );
      this.context.gitStatus = gitStatus.trim();
    } catch (error) {
      this.context.gitStatus = null;
    }

    // Phase 2: Enhanced context analysis
    try {
      const enhancedContext = await this.contextAnalyzer.analyzeEnvironment(
        this.context
      );

      // Merge enhanced context with basic context
      this.context = {
        ...this.context,
        ...enhancedContext,
        // Add command history for context
        recentCommands: this.memory.commands
          ? this.memory.commands.slice(-10)
          : [],
      };

      console.log(chalk.gray('🔍 Enhanced context analysis complete'));
    } catch (error) {
      console.warn(
        chalk.yellow(
          '⚠️  Enhanced context analysis failed, using basic context'
        )
      );
    }
  }

  execPromise(command) {
    return new Promise((resolve, reject) => {
      exec(command, (error, stdout, stderr) => {
        if (error) {
          reject(error);
        } else {
          resolve(stdout);
        }
      });
    });
  }

  async selectBestModel(prompt) {
    // Phase 2: Enhanced model selection using ModelSelector
    const availableModels = [];

    // Determine available models based on API keys
    if (this.config.openaiApiKey) {
      availableModels.push('gpt-4', 'gpt-3.5-turbo');
    }
    if (this.config.anthropicApiKey) {
      availableModels.push(
        'claude-3-5-sonnet-20241022',
        'claude-3-haiku-20240307'
      );
    }

    // If no API keys configured, fall back to simple logic
    if (availableModels.length === 0) {
      return this.config.preferredModel || 'gpt-4';
    }

    // Use enhanced model selection
    try {
      const selectedModel = this.modelSelector.selectOptimalModel(
        prompt,
        this.context,
        this.config,
        availableModels
      );

      // Track model performance for future decisions
      this.modelSelector.trackModelUsage(selectedModel, prompt);

      return selectedModel;
    } catch (error) {
      console.warn(
        chalk.yellow('⚠️  Advanced model selection failed, using fallback')
      );

      // Fallback to simple heuristics
      const promptLower = prompt.toLowerCase();
      if (
        promptLower.includes('code') ||
        promptLower.includes('programming') ||
        promptLower.includes('debug')
      ) {
        return this.config.openaiApiKey
          ? 'gpt-4'
          : 'claude-3-5-sonnet-20241022';
      } else if (
        promptLower.includes('analysis') ||
        promptLower.includes('research') ||
        promptLower.includes('explain')
      ) {
        return this.config.anthropicApiKey
          ? 'claude-3-5-sonnet-20241022'
          : 'gpt-4';
      } else {
        return this.config.preferredModel || 'gpt-4';
      }
    }
  }

  async queryAI(prompt, model = null) {
    // Phase 3: Execute beforeAIQuery hooks
    await this.pluginManager.executeHooks('beforeAIQuery', {
      prompt,
      model,
      context: this.context,
    });

    if (!model) {
      model = await this.selectBestModel(prompt);
    }

    const contextPrompt = `
Context:
- Working Directory: ${this.context.workingDirectory}
- Platform: ${this.context.platform}
- User: ${this.context.user}
- Shell: ${this.context.shell}
- Project Type: ${this.context.projectType || 'Unknown'}
- Git Status: ${this.context.gitStatus || 'Not a git repository'}

Recent Commands: ${JSON.stringify(this.memory.commands.slice(-5), null, 2)}

User Request: ${prompt}

Please provide a helpful response considering the context. If the user is asking for a command to run, provide the exact command(s) and explain what they do.
`;

    try {
      let aiResponse;

      if (model.startsWith('gpt') && this.openai) {
        const response = await this.openai.chat.completions.create({
          model: model,
          messages: [{ role: 'user', content: contextPrompt }],
          max_tokens: 1000,
        });
        aiResponse = response.choices[0].message.content;
      } else if (model.startsWith('claude') && this.anthropic) {
        const response = await this.anthropic.messages.create({
          model:
            model === 'claude-3-sonnet'
              ? 'claude-3-5-sonnet-20241022'
              : 'claude-3-haiku-20240307',
          max_tokens: 1000,
          messages: [{ role: 'user', content: contextPrompt }],
        });
        aiResponse = response.content[0].text;
      } else {
        throw new Error('No AI model available. Please configure API keys.');
      }

      // Phase 3: Execute afterAIQuery hooks
      await this.pluginManager.executeHooks('afterAIQuery', {
        prompt,
        model,
        response: aiResponse,
        context: this.context,
      });

      return aiResponse;
    } catch (error) {
      // Phase 3: Execute error hooks
      await this.pluginManager.executeHooks('onError', {
        error,
        context: 'AI_QUERY',
        prompt,
        model,
      });
      throw new Error(`AI query failed: ${error.message}`);
    }
  }

  async executeCommand(command, args = []) {
    const fullCommand = `${command} ${args.join(' ')}`;

    // Phase 3: Execute beforeCommand hooks
    await this.pluginManager.executeHooks('beforeCommand', {
      command: fullCommand,
      args,
      context: this.context,
    });

    // Phase 2: Enhanced command intelligence
    try {
      // Validate command safety
      const safetyCheck = this.commandIntelligence.validateCommandSafety(
        fullCommand,
        this.context
      );
      if (!safetyCheck.safe) {
        console.warn(chalk.yellow('⚠️  Safety Warning:'), safetyCheck.warning);

        const { confirmExecution } = await inquirer.prompt([
          {
            type: 'confirm',
            name: 'confirmExecution',
            message: 'Do you still want to execute this command?',
            default: false,
          },
        ]);

        if (!confirmExecution) {
          console.log(chalk.gray('Command execution cancelled.'));
          return { cancelled: true };
        }
      }

      // Get command optimization suggestions
      const optimization = this.commandIntelligence.suggestCommandOptimization(
        fullCommand,
        this.context
      );
      if (optimization.suggestion && optimization.suggestion !== fullCommand) {
        console.log(
          chalk.blue('💡 Optimization suggestion:'),
          chalk.cyan(optimization.suggestion)
        );
        console.log(chalk.gray('Reason:'), optimization.reason);

        const { useOptimization } = await inquirer.prompt([
          {
            type: 'confirm',
            name: 'useOptimization',
            message: 'Use the optimized command instead?',
            default: true,
          },
        ]);

        if (useOptimization) {
          // Parse the optimized command
          const parts = optimization.suggestion.split(' ');
          command = parts[0];
          args = parts.slice(1);
          console.log(chalk.green('✨ Using optimized command'));
        }
      }
    } catch (error) {
      console.warn(
        chalk.yellow(
          '⚠️  Command intelligence analysis failed, proceeding with execution'
        )
      );
    }

    // Store command in memory
    this.memory.commands.push({
      command: fullCommand,
      timestamp: new Date().toISOString(),
      workingDirectory: this.context.workingDirectory,
    });

    // Sync with memory manager
    this.memoryManager.memory = this.memory;

    // Keep only last 100 commands
    if (this.memory.commands.length > 100) {
      this.memory.commands = this.memory.commands.slice(-100);
    }

    await this.saveMemory();

    // Phase 3: Execute afterCommand hooks
    await this.pluginManager.executeHooks('afterCommand', {
      command: fullCommand,
      args,
      context: this.context,
      success: true,
    });

    const startTime = Date.now();

    return new Promise((resolve, reject) => {
      const child = spawn(command, args, {
        stdio: ['pipe', 'pipe', 'pipe'],
        cwd: this.context.workingDirectory,
      });

      let stdout = '';
      let stderr = '';

      child.stdout.on('data', (data) => {
        const output = data.toString();
        stdout += output;
        process.stdout.write(output);
      });

      child.stderr.on('data', (data) => {
        const output = data.toString();
        stderr += output;
        process.stderr.write(output);
      });

      child.on('error', (error) => {
        if (error.code === 'ENOENT') {
          reject(new Error(`Command "${command}" not found.`));
        } else {
          reject(new Error(`Failed to start subprocess: ${error.message}`));
        }
      });

      child.on('close', (code, signal) => {
        const endTime = Date.now();
        const executionResult = {
          success: code === 0,
          output: stdout,
          error: stderr,
          duration: endTime - startTime,
          exitCode: code,
        };

        // Phase 3: Record workflow step if recording is active
        this.workflowManager.recordStep(
          command,
          args,
          this.context,
          executionResult
        );

        if (signal) {
          reject(new Error(`Subprocess killed by signal: ${signal}`));
        } else {
          resolve({ code, stdout, stderr });
        }
      });
    });
  }

  async askAI(query) {
    const spinner = ora('Thinking...').start();

    try {
      // Phase 2: Command prediction before AI query
      let predictedCommands = [];
      try {
        predictedCommands = this.commandIntelligence.predictNextCommands(
          query,
          this.context,
          this.memory.commands || []
        );

        if (predictedCommands.length > 0) {
          spinner.stop();
          console.log(chalk.blue('🔮 Predicted commands based on your query:'));
          predictedCommands.forEach((cmd, index) => {
            console.log(
              `  ${index + 1}. ${chalk.cyan(cmd.command)} ${chalk.gray(
                '(confidence: ' + Math.round(cmd.confidence * 100) + '%)'
              )}`
            );
          });

          const { usePrediction } = await inquirer.prompt([
            {
              type: 'confirm',
              name: 'usePrediction',
              message:
                'Would you like to execute one of these predicted commands instead of asking AI?',
              default: false,
            },
          ]);

          if (usePrediction) {
            const { selectedCommand } = await inquirer.prompt([
              {
                type: 'list',
                name: 'selectedCommand',
                message: 'Select a command to execute:',
                choices: [
                  ...predictedCommands.map((cmd, index) => ({
                    name: `${cmd.command} (${Math.round(
                      cmd.confidence * 100
                    )}% confidence)`,
                    value: cmd.command,
                  })),
                  { name: 'None - Ask AI instead', value: null },
                ],
              },
            ]);

            if (selectedCommand) {
              const [cmd, ...args] = selectedCommand.split(' ');
              return await this.executeCommand(cmd, args);
            }
          }

          spinner.start('Thinking...');
        }
      } catch (error) {
        console.warn(
          chalk.yellow(
            '⚠️  Command prediction failed, proceeding with AI query'
          )
        );
      }

      const response = await this.queryAI(query);
      spinner.stop();

      // Store conversation in memory
      const conversation = {
        query,
        response,
        timestamp: new Date().toISOString(),
        context: { ...this.context },
      };

      this.memory.conversations.push(conversation);

      // Phase 3: Record workflow step if recording is active
      this.workflowManager.recordAIQuery(
        query,
        this.selectedModel || 'auto',
        this.context,
        response
      );

      // Sync with memory manager
      this.memoryManager.memory = this.memory;

      // Keep only last 50 conversations
      if (this.memory.conversations.length > 50) {
        this.memory.conversations = this.memory.conversations.slice(-50);
      }

      await this.saveMemory();

      // Format and display AI response with enhanced styling
      this.formatAIResponse(response);

      // Check if response contains commands to execute
      const commandMatch = response.match(/```(?:bash|shell|sh)?\n(.*?)\n```/s);
      if (commandMatch) {
        const suggestedCommand = commandMatch[1].trim();

        // Display the command suggestion with enhanced formatting
        this.displayCommandSuggestion(
          suggestedCommand,
          'AI suggested this command based on your query'
        );

        const { executeCommand } = await inquirer.prompt([
          {
            type: 'confirm',
            name: 'executeCommand',
            message: 'Would you like to execute this command?',
            default: false,
          },
        ]);

        if (executeCommand) {
          const [cmd, ...args] = suggestedCommand.split(' ');
          await this.executeCommand(cmd, args);
        }
      }
    } catch (error) {
      spinner.stop();
      console.error(chalk.red('Error:', error.message));
    }
  }

  // Format and display AI response with enhanced styling
  formatAIResponse(response) {
    console.log(chalk.blue('\n🤖 AI Response:'));
    console.log(chalk.gray('─'.repeat(60)));

    // Split response into lines for processing
    const lines = response.split('\n');
    let inCodeBlock = false;
    let codeLanguage = '';
    let listLevel = 0;

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i];

      // Handle code blocks
      if (line.match(/^```(\w+)?/)) {
        if (!inCodeBlock) {
          codeLanguage = line.match(/^```(\w+)?/)[1] || 'text';
          inCodeBlock = true;
          console.log(chalk.gray(`\n┌─ Code (${codeLanguage}) ─`));
          continue;
        } else {
          inCodeBlock = false;
          console.log(chalk.gray('└─────────────────'));
          continue;
        }
      }

      // Handle inline code
      if (!inCodeBlock && line.includes('`')) {
        const formattedLine = line.replace(/`([^`]+)`/g, (match, code) => {
          return chalk.bgGray.black(` ${code} `);
        });
        console.log(formattedLine);
        continue;
      }

      // Handle code block content
      if (inCodeBlock) {
        console.log(chalk.green(`│ ${line}`));
        continue;
      }

      // Handle headers
      if (line.match(/^#{1,6}\s/)) {
        const level = line.match(/^(#{1,6})/)[1].length;
        const text = line.replace(/^#{1,6}\s/, '');

        if (level === 1) {
          console.log(chalk.yellow.bold(`\n${text}`));
          console.log(chalk.yellow('═'.repeat(Math.min(text.length, 50))));
        } else if (level === 2) {
          console.log(chalk.cyan.bold(`\n${text}`));
          console.log(chalk.cyan('─'.repeat(Math.min(text.length, 40))));
        } else {
          console.log(chalk.white.bold(`\n${'  '.repeat(level - 3)}${text}`));
        }
        continue;
      }

      // Handle numbered lists
      if (line.match(/^\d+\.\s/)) {
        const content = line.replace(/^\d+\.\s/, '');
        console.log(chalk.blue(`   ${line.match(/^\d+/)[0]}.`) + ` ${content}`);
        continue;
      }

      // Handle bullet lists
      if (line.match(/^[\s]*[-\*\+]\s/)) {
        const indent = line.match(/^(\s*)/)[1].length;
        const content = line.replace(/^[\s]*[-\*\+]\s/, '');
        const bullet = indent === 0 ? '•' : '◦';
        console.log(
          `${'  '.repeat(Math.floor(indent / 2))}${chalk.yellow(
            bullet
          )} ${content}`
        );
        continue;
      }

      // Handle blockquotes
      if (line.match(/^>\s/)) {
        const content = line.replace(/^>\s/, '');
        console.log(chalk.blue(`▌ ${content}`));
        continue;
      }

      // Handle horizontal rules
      if (
        line.match(/^---+$/) ||
        line.match(/^\*\*\*+$/) ||
        line.match(/^___+$/)
      ) {
        console.log(chalk.gray('─'.repeat(50)));
        continue;
      }

      // Handle warning/note blocks
      if (line.match(/^(Note:|Warning:|Important:|Tip:)/i)) {
        const type = line
          .match(/^(Note|Warning|Important|Tip):/i)[1]
          .toLowerCase();
        const content = line.replace(
          /^(Note:|Warning:|Important:|Tip:)\s*/i,
          ''
        );

        let icon = '💡';
        let color = chalk.blue;

        if (type === 'warning') {
          icon = '⚠️';
          color = chalk.yellow;
        } else if (type === 'important') {
          icon = '❗';
          color = chalk.red;
        } else if (type === 'tip') {
          icon = '💡';
          color = chalk.green;
        }

        console.log(color(`\n${icon} ${type.toUpperCase()}: ${content}`));
        continue;
      }

      // Handle tables (basic support)
      if (line.includes('|') && (line.match(/\|/g) || []).length >= 2) {
        // Simple table row formatting
        const cells = line
          .split('|')
          .map((cell) => cell.trim())
          .filter((cell) => cell);
        const formattedCells = cells.map((cell) => cell.padEnd(15)).join(' │ ');
        console.log(chalk.cyan(`│ ${formattedCells} │`));
        continue;
      }

      // Handle empty lines
      if (line.trim() === '') {
        console.log('');
        continue;
      }

      // Regular text
      console.log(line);
    }

    console.log(chalk.gray('\n─'.repeat(60)));
  }

  async configure() {
    console.log(chalk.yellow('🔧 AIA Configuration'));

    const answers = await inquirer.prompt([
      {
        type: 'input',
        name: 'openaiApiKey',
        message: 'OpenAI API Key (leave empty to skip):',
        default: this.config.openaiApiKey || '',
      },
      {
        type: 'input',
        name: 'anthropicApiKey',
        message: 'Anthropic API Key (leave empty to skip):',
        default: this.config.anthropicApiKey || '',
      },
      {
        type: 'list',
        name: 'preferredModel',
        message: 'Preferred AI Model:',
        choices: [
          'gpt-4',
          'gpt-3.5-turbo',
          'claude-3-sonnet',
          'claude-3-haiku',
        ],
        default: this.config.preferredModel || 'gpt-4',
      },
    ]);

    this.config = { ...this.config, ...answers };
    await this.saveConfig();
    this.initializeAI();

    console.log(chalk.green('✅ Configuration saved!'));
  }

  async showMemory() {
    console.log(chalk.yellow('🧠 Memory Summary'));
    console.log(
      chalk.cyan(`Commands executed: ${this.memory.commands.length}`)
    );
    console.log(
      chalk.cyan(`Conversations: ${this.memory.conversations.length}`)
    );

    if (this.memory.commands.length > 0) {
      console.log(chalk.blue('\nRecent Commands:'));
      this.memory.commands.slice(-10).forEach((cmd) => {
        console.log(
          `  ${chalk.gray(cmd.timestamp)}: ${chalk.white(cmd.command)}`
        );
      });
    }

    if (this.memory.conversations.length > 0) {
      console.log(chalk.blue('\nRecent Conversations:'));
      this.memory.conversations.slice(-5).forEach((conv) => {
        console.log(
          `  ${chalk.gray(conv.timestamp)}: ${chalk.white(
            conv.query.substring(0, 60)
          )}...`
        );
      });
    }
  }

  async clearMemory() {
    const { confirm } = await inquirer.prompt([
      {
        type: 'confirm',
        name: 'confirm',
        message: 'Are you sure you want to clear all memory?',
        default: false,
      },
    ]);

    if (confirm) {
      this.memory = {
        conversations: [],
        commands: [],
        preferences: {},
        workingDirectories: {},
        metadata: {
          created: new Date().toISOString(),
          version: '2.0.0',
          totalQueries: 0,
          lastCleanup: null,
        },
      };

      // Update memory manager with new empty memory
      this.memoryManager.memory = this.memory;
      await this.saveMemory();
      console.log(chalk.green('✅ Memory cleared!'));
    }
  }

  async semanticSearch(query, limit = 10) {
    // Basic semantic search implementation
    const results = this.memory.conversations
      .filter((conv) => {
        const content = `${conv.query} ${conv.response}`.toLowerCase();
        return content.includes(query.toLowerCase());
      })
      .slice(0, limit)
      .map((conv) => ({
        type: 'conversation',
        score: this.calculateRelevanceScore(conv, query),
        content: conv,
      }));

    // TODO: Enhance with semantic vector search

    return results;
  }

  calculateRelevanceScore(conversation, query) {
    // Basic relevance scoring based on keyword match
    const queryWords = query.toLowerCase().split(' ');
    const content =
      `${conversation.query} ${conversation.response}`.toLowerCase();

    const matches = queryWords.filter((word) => content.includes(word));
    return matches.length / queryWords.length;
  }

  // Enhanced command suggestion display
  displayCommandSuggestion(command, reason) {
    console.log(chalk.blue('\n💡 Command Suggestion:'));
    console.log(chalk.gray('┌─ Suggested Command ─'));
    console.log(chalk.green(`│ ${command}`));
    console.log(chalk.gray('└────────────────────'));
    if (reason) {
      console.log(chalk.dim(`💭 Reason: ${reason}`));
    }
  }

  // Enhanced error display
  displayError(error, context = '') {
    console.log(chalk.red('\n❌ Error:'));
    console.log(chalk.gray('┌─ Error Details ─'));
    console.log(chalk.red(`│ ${error}`));
    if (context) {
      console.log(chalk.yellow(`│ Context: ${context}`));
    }
    console.log(chalk.gray('└─────────────────'));
  }

  // Enhanced success message display
  displaySuccess(message, details = null) {
    console.log(chalk.green('\n✅ Success:'));
    console.log(chalk.gray('┌─ Success Details ─'));
    console.log(chalk.green(`│ ${message}`));
    if (details) {
      console.log(chalk.gray(`│ ${details}`));
    }
    console.log(chalk.gray('└───────────────────'));
  }
}

// Initialize AIA
const aia = new AIA();

// Function to pre-load plugins for CLI command registration
async function preloadPluginsForCLI() {
  try {
    await aia.init();
    // Plugin commands are already registered during init
  } catch (error) {
    // Silently fail plugin pre-loading to allow basic CLI functionality
    // console.warn(chalk.yellow('Plugin pre-loading warning:', error.message));
  }
}

// Program setup
program
  .name('aia')
  .description('AI-powered Agentic CLI Assistant')
  .version('1.0.0');

program
  .command('ask <query...>')
  .alias('q')
  .description('Ask the AI assistant a question')
  .action(async (query) => {
    await aia.init();
    await aia.askAI(query.join(' '));
  });

program
  .command('exec <command> [args...]')
  .alias('x')
  .description('Execute a command with AI context')
  .action(async (command, args = []) => {
    await aia.init();
    try {
      await aia.executeCommand(command, args);
    } catch (error) {
      console.error(chalk.red('Error:', error.message));
      process.exit(1);
    }
  });

program
  .command('config')
  .alias('c')
  .description('Configure AIA settings')
  .action(async () => {
    await aia.init();
    await aia.configure();
  });

program
  .command('memory')
  .alias('m')
  .description('Show memory summary')
  .action(async () => {
    await aia.init();
    await aia.showMemory();
  });

program
  .command('clear-memory')
  .description('Clear all stored memory')
  .action(async () => {
    await aia.init();
    await aia.clearMemory();
  });

program
  .command('context')
  .description('Show current context information')
  .action(async () => {
    await aia.init();
    console.log(chalk.yellow('📍 Current Context'));
    console.log(JSON.stringify(aia.context, null, 2));
  });

program
  .command('search <query...>')
  .description('Semantic search through memory')
  .option('-l, --limit <number>', 'Limit number of results', '10')
  .action(async (query, options) => {
    await aia.init();
    const searchQuery = query.join(' ');
    const limit = parseInt(options.limit);

    const spinner = ora('🔍 Searching memory...').start();
    try {
      const results = await aia.memoryManager.semanticSearch(
        searchQuery,
        limit
      );
      spinner.stop();

      if (results.length === 0) {
        console.log(chalk.yellow('No relevant results found.'));
        return;
      }

      console.log(
        chalk.green(`\n🔍 Found ${results.length} relevant results:`)
      );
      results.forEach((result, index) => {
        console.log(
          chalk.blue(
            `\n${
              index + 1
            }. ${result.type.toUpperCase()} (Score: ${result.score.toFixed(2)})`
          )
        );
        console.log(
          chalk.gray(`   Time: ${new Date(result.timestamp).toLocaleString()}`)
        );

        if (result.type === 'conversation') {
          console.log(chalk.white(`   Query: ${result.content.query}`));
          const preview = result.content.response?.substring(0, 100) || '';
          console.log(
            chalk.gray(
              `   Response: ${preview}${preview.length === 100 ? '...' : ''}`
            )
          );
        } else if (result.type === 'command') {
          console.log(chalk.white(`   Command: ${result.content.command}`));
          console.log(
            chalk.gray(`   Directory: ${result.content.workingDirectory}`)
          );
        }
      });
    } catch (error) {
      spinner.stop();
      console.error(chalk.red('Search failed:', error.message));
    }
  });

program
  .command('memory-stats')
  .description('Show memory statistics and health')
  .action(async () => {
    await aia.init();
    const stats = aia.memoryManager.getMemoryStats();

    console.log(chalk.blue('📊 Memory Statistics'));
    console.log(chalk.white(`Conversations: ${stats.conversations}`));
    console.log(chalk.white(`Commands: ${stats.commands}`));
    console.log(
      chalk.white(`Total Size: ${(stats.totalSize / 1024).toFixed(2)} KB`)
    );
    console.log(
      chalk.white(`Semantic Index: ${stats.semanticIndexSize} keywords`)
    );
    console.log(
      chalk.white(`Context Links: ${stats.contextLinks} directories`)
    );
    console.log(chalk.white(`Last Cleanup: ${stats.lastCleanup || 'Never'}`));

    if (stats.compressionNeeded) {
      console.log(chalk.yellow('⚠️  Memory compression recommended'));
    } else {
      console.log(chalk.green('✅ Memory size is optimal'));
    }
  });

program
  .command('memory-compress')
  .description('Compress memory to reduce size')
  .action(async () => {
    await aia.init();
    const spinner = ora('🗜️  Compressing memory...').start();

    try {
      const success = await aia.memoryManager.compressMemory();
      spinner.stop();

      if (success) {
        console.log(chalk.green('✅ Memory compression completed'));
        const stats = aia.memoryManager.getMemoryStats();
        console.log(
          chalk.white(`New size: ${(stats.totalSize / 1024).toFixed(2)} KB`)
        );
      } else {
        console.log(chalk.red('❌ Memory compression failed'));
      }
    } catch (error) {
      spinner.stop();
      console.error(chalk.red('Compression failed:', error.message));
    }
  });

program
  .command('memory-cleanup')
  .description('Smart cleanup of outdated memory')
  .action(async () => {
    await aia.init();
    const spinner = ora('🧹 Cleaning up memory...').start();

    try {
      const result = await aia.memoryManager.smartCleanup();
      spinner.stop();

      if (result.error) {
        console.log(chalk.red(`❌ Cleanup failed: ${result.error}`));
      } else {
        console.log(chalk.green('✅ Smart cleanup completed'));
        console.log(chalk.white(`Removed: ${result.removed} conversations`));
        console.log(
          chalk.white(`Remaining: ${result.remaining} conversations`)
        );
      }
    } catch (error) {
      spinner.stop();
      console.error(chalk.red('Cleanup failed:', error.message));
    }
  });

program
  .command('memory-export <path>')
