program
  .command('plugin-list')
  .description('List all available plugins')
  .action(async () => {
    await aia.init();
    const plugins = aia.pluginManager.getPluginList();

    console.log(chalk.blue('🔌 Installed Plugins'));

    if (plugins.length === 0) {
      console.log(chalk.gray('No plugins installed.'));
      console.log(
        chalk.yellow('💡 Install plugins with: aia plugin-install <name>')
      );
      return;
    }

    plugins.forEach((plugin) => {
      const status = plugin.loaded
        ? chalk.green('✓ loaded')
        : chalk.red('✗ unloaded');
      console.log(`${status} ${chalk.white(plugin.name)} v${plugin.version}`);
      if (plugin.description) {
        console.log(chalk.gray(`   ${plugin.description}`));
      }
      if (plugin.commands && plugin.commands.length > 0) {
        console.log(chalk.gray(`   Commands: ${plugin.commands.join(', ')}`));
      }
    });
  });

program
  .command('plugin-install <source>')
  .description('Install a plugin from various sources')
  .option('-n, --name <name>', 'Override plugin name')
  .addHelpText(
    'after',
    `
Examples:
  aia plugin-install ./my-plugin                    # Local directory
  aia plugin-install git+https://github.com/user/plugin.git  # Git repository  
  aia plugin-install some-npm-package               # NPM package
  aia plugin-install https://example.com/plugin.zip # Direct download URL
`
  )
  .action(async (source, options) => {
    await aia.init();
    const spinner = ora('🔄 Installing plugin...').start();

    try {
      const result = await aia.pluginManager.installPlugin(
        source,
        options.name
      );
      spinner.stop();

      if (result.success) {
        console.log(
          chalk.green(`✅ Plugin "${result.name}" installed successfully`)
        );
        if (result.version) {
          console.log(chalk.gray(`Version: ${result.version}`));
        }
        if (result.description) {
          console.log(chalk.gray(`Description: ${result.description}`));
        }
        if (result.commands && result.commands.length > 0) {
          console.log(
            chalk.gray(`Commands added: ${result.commands.join(', ')}`)
          );
        }
        if (result.source) {
          console.log(chalk.gray(`Source: ${result.source}`));
        }
      } else {
        console.log(chalk.red(`❌ Failed to install plugin: ${result.error}`));
      }
    } catch (error) {
      spinner.stop();
      console.error(chalk.red('Installation failed:', error.message));
    }
  });

program
  .command('plugin-uninstall <name>')
  .description('Uninstall a plugin')
  .action(async (name) => {
    await aia.init();

    const plugin = aia.pluginManager.getPluginInfo(name);
    if (!plugin) {
      console.log(chalk.red(`❌ Plugin "${name}" not found`));
      return;
    }

    const { confirm } = await inquirer.prompt([
      {
        type: 'confirm',
        name: 'confirm',
        message: `Are you sure you want to uninstall "${name}"?`,
        default: false,
      },
    ]);

    if (!confirm) {
      console.log(chalk.gray('Uninstall cancelled.'));
      return;
    }

    const spinner = ora('🗑️  Uninstalling plugin...').start();

    try {
      const result = await aia.pluginManager.uninstallPlugin(name);
      spinner.stop();

      if (result.success) {
        console.log(
          chalk.green(`✅ Plugin "${name}" uninstalled successfully`)
        );
      } else {
        console.log(
          chalk.red(`❌ Failed to uninstall plugin: ${result.error}`)
        );
      }
    } catch (error) {
      spinner.stop();
      console.error(chalk.red('Uninstall failed:', error.message));
    }
  });

program
  .command('plugin-reload <name>')
  .description('Reload a plugin (hot reload)')
  .action(async (name) => {
    await aia.init();
    const spinner = ora('🔄 Reloading plugin...').start();

    try {
      await aia.pluginManager.reloadPlugin(name);
      spinner.stop();
      console.log(chalk.green(`✅ Plugin "${name}" reloaded successfully`));
    } catch (error) {
      spinner.stop();
      console.error(chalk.red('Reload failed:', error.message));
    }
  });

program
  .command('plugin-info <name>')
  .description('Show detailed plugin information')
  .action(async (name) => {
    await aia.init();
    const plugin = aia.pluginManager.getPluginInfo(name);

    if (!plugin) {
      console.log(chalk.red(`❌ Plugin "${name}" not found`));
      return;
    }

    console.log(chalk.blue(`🔌 Plugin Information: ${plugin.name}`));
    console.log(chalk.white(`Version: ${plugin.version}`));
    console.log(
      chalk.white(
        `Status: ${
          plugin.loaded ? chalk.green('Loaded') : chalk.red('Unloaded')
        }`
      )
    );

    if (plugin.description) {
      console.log(chalk.white(`Description: ${plugin.description}`));
    }

    if (plugin.author) {
      console.log(chalk.white(`Author: ${plugin.author}`));
    }

    if (plugin.homepage) {
      console.log(chalk.white(`Homepage: ${plugin.homepage}`));
    }

    if (plugin.commands && plugin.commands.length > 0) {
      console.log(chalk.white(`Commands: ${plugin.commands.join(', ')}`));
    }

    if (plugin.hooks && plugin.hooks.length > 0) {
      console.log(chalk.white(`Hooks: ${plugin.hooks.join(', ')}`));
    }

    if (plugin.dependencies && Object.keys(plugin.dependencies).length > 0) {
      console.log(chalk.white('Dependencies:'));
      Object.entries(plugin.dependencies).forEach(([dep, version]) => {
        console.log(chalk.gray(`  ${dep}: ${version}`));
      });
    }
  });

program
  .command('plugin-stats')
  .description('Show plugin system statistics')
  .action(async () => {
    await aia.init();
    const stats = aia.pluginManager.getPluginStats();

    console.log(chalk.blue('🔌 Plugin System Statistics'));
    console.log(chalk.white(`Total plugins: ${stats.total}`));
    console.log(chalk.white(`Loaded plugins: ${stats.loaded}`));
    console.log(chalk.white(`Failed plugins: ${stats.failed}`));
    console.log(chalk.white(`Total hooks registered: ${stats.totalHooks}`));
    console.log(chalk.white(`Commands added: ${stats.totalCommands}`));

    if (stats.loadTime) {
      console.log(chalk.white(`Load time: ${stats.loadTime}ms`));
    }

    if (stats.memoryUsage) {
      console.log(
        chalk.white(
          `Memory usage: ${(stats.memoryUsage / 1024 / 1024).toFixed(2)} MB`
        )
      );
    }

    if (stats.hookExecutions) {
      console.log(chalk.white(`Hook executions: ${stats.hookExecutions}`));
    }
  });

program
  .command('plugin-search <query>')
  .description('Search for plugins in registries')
  .option('-s, --source <source>', 'Search source (npm, aia, all)', 'all')
  .option('-l, --limit <limit>', 'Maximum number of results', '10')
  .action(async (query, options) => {
    await aia.init();
    const spinner = ora('🔍 Searching for plugins...').start();

    try {
      const results = await aia.pluginManager.searchPlugins(query, {
        source: options.source,
        limit: parseInt(options.limit, 10),
      });
      spinner.stop();

      if (results.length === 0) {
        console.log(chalk.yellow(`No plugins found matching "${query}"`));
        console.log(
          chalk.gray('\nTry searching with different keywords or check:')
        );
        console.log(
          chalk.gray(
            '  - NPM packages: https://www.npmjs.com/search?q=aia-plugin'
          )
        );
        console.log(
          chalk.gray('  - GitHub: https://github.com/search?q=aia-plugin')
        );
        return;
      }

      console.log(
        chalk.blue(`🔍 Found ${results.length} plugin(s) matching "${query}"`)
      );
      console.log();

      results.forEach((plugin, index) => {
        console.log(chalk.white(`${index + 1}. ${plugin.name}`));
        if (plugin.description) {
          console.log(chalk.gray(`   ${plugin.description}`));
        }
        if (plugin.version) {
          console.log(chalk.gray(`   Version: ${plugin.version}`));
        }
        if (plugin.author) {
          console.log(chalk.gray(`   Author: ${plugin.author}`));
        }
        if (plugin.source) {
          console.log(chalk.gray(`   Source: ${plugin.source}`));
        }
        if (plugin.installCommand) {
          console.log(
            chalk.green(
              `   Install: aia plugin-install ${plugin.installCommand}`
            )
          );
        }
        console.log();
      });
    } catch (error) {
      spinner.stop();
      console.error(chalk.red('Search failed:', error.message));
    }
  });

program
  .command('plugin-discover')
  .description('Discover popular and featured plugins')
  .option(
    '-c, --category <category>',
    'Filter by category (dev, productivity, fun, etc.)'
  )
  .action(async (options) => {
    await aia.init();
    const spinner = ora('🌟 Discovering plugins...').start();

    try {
      const featured = await aia.pluginManager.getFeaturedPlugins({
        category: options.category,
      });
      spinner.stop();

      if (featured.length === 0) {
        console.log(
          chalk.yellow('No featured plugins available at this time.')
        );
        console.log(chalk.gray('\nYou can still install plugins from:'));
        console.log(
          chalk.gray('  - Local directories: aia plugin-install ./my-plugin')
        );
        console.log(
          chalk.gray(
            '  - Git repositories: aia plugin-install git+https://github.com/user/plugin.git'
          )
        );
        console.log(
          chalk.gray('  - NPM packages: aia plugin-install package-name')
        );
        return;
      }

      console.log(chalk.blue('🌟 Featured AIA Plugins'));
      console.log();

      featured.forEach((plugin, index) => {
        const status = plugin.installed
          ? chalk.green('✅ Installed')
          : chalk.gray('⬜ Available');

        console.log(chalk.white(`${status} ${plugin.name}`));
        if (plugin.description) {
          console.log(chalk.gray(`   ${plugin.description}`));
        }
        if (plugin.category) {
          console.log(chalk.gray(`   Category: ${plugin.category}`));
        }
        if (plugin.downloads) {
          console.log(chalk.gray(`   Downloads: ${plugin.downloads}`));
        }
        if (!plugin.installed && plugin.installCommand) {
          console.log(
            chalk.green(
              `   Install: aia plugin-install ${plugin.installCommand}`
            )
          );
        }
        console.log();
      });
    } catch (error) {
      spinner.stop();
      console.error(chalk.red('Discovery failed:', error.message));
    }
  });

program
  .command('plugin-create <name>')
  .description('Create a new plugin template')
  .option('-d, --directory <dir>', 'Target directory for plugin', '.')
