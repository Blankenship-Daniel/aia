{
  "name": "aia-cli",
  "version": "1.0.0",
  "description": "An intelligent, agentic CLI tool that executes commands with AI assistance, context awareness, and memory",
  "main": "main.js",
  "bin": {
    "aia": "./main.js"
  },
  "scripts": {
    "start": "node index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blankenship-Daniel/aia.git"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "automation",
    "context-aware",
    "memory"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Blankenship-Daniel/aia/issues"
  },
  "homepage": "https://github.com/Blankenship-Daniel/aia#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "axios": "^1.10.0",
    "chalk": "^4.1.2",
    "commander": "^14.0.0",
    "dirty-json": "^0.9.2",
    "extract-first-json": "^2.0.2",
    "fs-extra": "^11.3.0",
    "inquirer": "^8.2.6",
    "json5": "^2.2.3",
    "jsonic": "^2.16.0",
    "openai": "^5.5.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "jest": "^30.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "index.js",
      "!**/node_modules/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.js"
    ]
  },
  "packageManager": "yarn@1.22.19+sha512.ff4579ab459bb25aa7c0ff75b62acebe576f6084b36aa842971cf250a5d8c6cd3bc9420b22ce63c7f93a0857bc6ef29291db39c3e7a23aab5adfd5a4dd6c5d71"
}
