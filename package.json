{
  "name": "aia-cli",
  "version": "1.0.0",
  "description": "An intelligent, agentic CLI tool that executes commands with AI assistance, context awareness, and memory",
  "main": "main.js",
  "bin": {
    "aia": "./main.js"
  },
  "scripts": {
    "start": "node index.js",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:clean": "rimraf dist && npm run build",
    "build:production": "npm run build:clean && npm run copy-assets",
    "copy-assets": "shx cp -r examples dist/ 2>/dev/null || true",
    "dev": "concurrently \"npm run build:watch\" \"nodemon dist/main.js\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ts": "jest --config jest.config.ts",
    "lint": "npx @typescript-eslint/eslint-plugin --help || echo 'ESLint not configured'",
    "pretest": "npm run type-check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blankenship-Daniel/aia.git"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "automation",
    "context-aware",
    "memory"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Blankenship-Daniel/aia/issues"
  },
  "homepage": "https://github.com/Blankenship-Daniel/aia#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "axios": "^1.10.0",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.3",
    "commander": "^14.0.0",
    "dirty-json": "^0.9.2",
    "extract-first-json": "^2.0.2",
    "fs-extra": "^11.3.0",
    "inquirer": "^8.2.6",
    "json5": "^2.2.3",
    "jsonic": "^2.16.0",
    "openai": "^5.5.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.0",
    "@types/chalk": "^0.4.31",
    "@types/commander": "^2.12.0",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.8",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.3",
    "@types/ora": "^3.1.0",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vercel/ncc": "^0.38.3",
    "concurrently": "^9.1.2",
    "dependency-cruiser": "^16.10.3",
    "jest": "^30.0.0",
    "nodemon": "^3.1.10",
    "rimraf": "^6.0.1",
    "shx": "^0.4.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "packageManager": "yarn@1.22.19+sha512.ff4579ab459bb25aa7c0ff75b62acebe576f6084b36aa842971cf250a5d8c6cd3bc9420b22ce63c7f93a0857bc6ef29291db39c3e7a23aab5adfd5a4dd6c5d71"
}
